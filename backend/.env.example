# Copy this file to `.env` for local dev. Render: set the same keys as
# environment variables on the Web Service.

# Postgres connection string. Render provides this as `DATABASE_URL` on a
# managed Postgres add-on. For local dev, SQLite is used automatically if
# this is unset.
DATABASE_URL=postgresql://user:password@localhost:5432/simucast

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGINS=http://localhost:5173

# Anthropic API key for the /api/ai routes.
ANTHROPIC_API_KEY=sk-ant-...
